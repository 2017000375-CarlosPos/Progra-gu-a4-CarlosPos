Console.WriteLine("=== CLASIFICACIÓN DE TRIÁNGULOS ===");

        Console.Write("Ingrese la medida del primer lado: ");
        double lado1 = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingrese la medida del segundo lado: ");
        double lado2 = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingrese la medida del tercer lado: ");
        double lado3 = Convert.ToDouble(Console.ReadLine());

        if ((lado1 + lado2 > lado3) && (lado1 + lado3 > lado2) && (lado2 + lado3 > lado1))
        {
            if (lado1 == lado2 && lado2 == lado3)
            {
                Console.WriteLine("\nEl triángulo es: EQUILÁTERO (todos sus lados son iguales).");
            }
            else if (lado1 == lado2 || lado1 == lado3 || lado2 == lado3)
            {
                Console.WriteLine("\nEl triángulo es: ISÓSCELES (tiene dos lados iguales).");
            }
            else
            {
                Console.WriteLine("\nEl triángulo es: ESCALENO (todos sus lados son diferentes).");
            }
        }
        else
        {
            Console.WriteLine("\nLas medidas ingresadas no pueden formar un triángulo válido.");
        }
